-- Vector sum with multiple supers (Trebuchet-style structure)

-- super 1: single, builds base vector [0 .. 99]
init_vec dummy =
  super initImpl dummy (
    initImpl _ = fromList [0 .. 99]
  )

-- super 2: parallel, builds encoded (a,b) pairs where b = a + 1
fill_pairs xs =
  super fillImpl xs (
    fillImpl xs =
      let pairs = map (\x -> encPair x (x + 1)) (toList xs)
      in fromList pairs
  )

-- super 3: parallel, computes c[i] = a[i] + b[i]
add_pairs pairs =
  super addImpl pairs (
    addImpl pairs =
      let sums = map (\p -> fstDec p + sndDec p) (toList pairs)
      in fromList sums
  )

main =
  printl (add_pairs (fill_pairs (init_vec [])))
